---
import { Badge } from "@/components/ui/Badge";
import { Button } from "@/components/ui/Button";
import type { ToolCard as ToolCardData } from "@/lib/types";

interface Props extends ToolCardData {}

const { id, title, description, href, tags } = Astro.props as Props;

const dataTags = tags.map((tag) => tag.toLowerCase()).join(" ");
---

<article
  id={id}
  class="tool-card border-border bg-background-1 group border p-6"
  data-tool-card
  data-tags={dataTags}
>
  <div
    class="h-1 w-full bg-linear-90 from-accent via-accent to-accent-3 bg-accent mb-8"
    aria-hidden="true"
  >
  </div>

  <div class="mt-5 space-y-5">
    <div class="space-y-2">
      <h2 class="text-foreground-0 text-xl font-semibold">{title}</h2>
    </div>

    <p class="text-foreground-1 text-sm leading-relaxed">{description}</p>

    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => <Badge variant="outline">{tag}</Badge>)}
    </div>

    {
      href && (
        <div>
          <Button as="a" href={href} variant="default">
            Open tool
          </Button>
        </div>
      )
    }
  </div>
</article>
