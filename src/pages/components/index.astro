---
import { getCollection } from "astro:content";
import { Badge } from "@/components/ui/Badge";
import BaseLayout from "@/layouts/BaseLayout.astro";

const components = await getCollection("components");
---

<BaseLayout
  title="Components"
  description="A concise list of the custom components available in this project."
>
  <section
    class="stripe-pattern-dense relative flex items-center justify-center bg-background-0 px-4 py-12 md:px-12"
  >
    <div class="mx-auto w-full max-w-7xl">
      <!-- Greeter -->
      <div class="mb-16">
        <Badge variant="accent">Components</Badge>
        <h1 class="text-section-heading my-8">
          <div>User</div>
          <div>Interface</div>
        </h1>

        <p
          class="text-foreground-1 max-w-2xl space-y-6 text-base leading-relaxed md:text-lg"
        >
          Click a link to view the source layout for that component.
        </p>
      </div>

      <!-- All projects -->
      <div class="space-y-4">
        {
          components.map((component) => (
            <a
              href={`/components/${component.id}`}
              class="group border-border hover:bg-background-1 flex items-center justify-between border px-6 py-5 transition-colors"
            >
              <span class="text-foreground-0 text-lg font-semibold">
                {component.data.title}
              </span>
              <span class="text-foreground-2 text-xs tracking-widest uppercase">
                view component
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
