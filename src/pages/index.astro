---
import { SITE } from "@data/config";
import { Badge } from "@/components/ui/Badge";
import { Button } from "@/components/ui/Button";
import ToolCard from "@/components/tools/ToolCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import toolsData from "@data/tools.json";
import type { ToolCard as ToolCardData } from "@/lib/types";

const tools = toolsData as ToolCardData[];

const filterMap = new Map<string, string>();

for (const tool of tools) {
  for (const tag of tool.tags) {
    const filterId = tag.toLowerCase();

    if (!filterMap.has(filterId)) {
      filterMap.set(filterId, tag);
    }
  }
}

const filters = [
  { id: "all", label: "All tools" },
  ...Array.from(filterMap, ([id, label]) => ({ id, label })),
];
---

<BaseLayout
  title={SITE.title}
  description="A growing collection of small, focused tools for quick workflows and repeat tasks."
>
  <section
    class="stripe-pattern-dense relative min-h-screen px-4 py-12 md:px-12"
  >
    <div class="mx-auto w-full max-w-7xl space-y-8">
      <header class="max-w-3xl space-y-5">
        <Badge variant="accent">Toolkit</Badge>

        <div class="space-y-4">
          <h1 class="text-section-heading">
            <div>Small tools.</div>
            <div>Fast results.</div>
          </h1>

          <p
            class="text-foreground-1 max-w-2xl text-base leading-relaxed md:text-lg"
          >
            Toolkit is a growing collection of focused web tools for repetitive
            tasks, quick utility pages, and lightweight one-off workflows.
            Build, launch, and use them without server complexity.
          </p>
        </div>
      </header>

      <div class="flex flex-wrap items-center gap-2">
        {
          filters.map((filter, index) => (
            <Button
              type="button"
              variant="outline"
              className="text-xs uppercase"
              data-tool-filter={filter.id}
              aria-pressed={index === 0 ? "true" : "false"}
            >
              {filter.label}
            </Button>
          ))
        }
      </div>

      <div id="tool-empty-state" class="border-border hidden border p-6">
        <p class="text-foreground-1 text-sm leading-relaxed">
          No tools match that filter yet. Try another category.
        </p>
      </div>

      <div id="tool-grid" class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {tools.map((tool) => <ToolCard {...tool} />)}
      </div>
    </div>
  </section>

  <script is:inline type="module">
    const filterButtons = Array.from(
      document.querySelectorAll("[data-tool-filter]"),
    );
    const cards = Array.from(document.querySelectorAll("[data-tool-card]"));
    const emptyState = document.querySelector("#tool-empty-state");

    function applyFilter(filterId) {
      let visibleCount = 0;

      cards.forEach((card) => {
        const tags = (card.getAttribute("data-tags") ?? "").split(" ");
        const isVisible = filterId === "all" || tags.includes(filterId);

        card.hidden = !isVisible;

        if (isVisible) visibleCount += 1;
      });

      if (emptyState) {
        emptyState.classList.toggle("hidden", visibleCount > 0);
      }

      filterButtons.forEach((button) => {
        const isActive = button.getAttribute("data-tool-filter") === filterId;

        button.setAttribute("aria-pressed", String(isActive));
        button.classList.toggle("border-foreground-0", isActive);
        button.classList.toggle("bg-foreground-0", isActive);
        button.classList.toggle("text-background-0", isActive);
        button.classList.toggle("text-foreground-1", !isActive);
        button.classList.toggle("border-border", !isActive);
        button.classList.toggle("bg-transparent", !isActive);
        button.classList.toggle("hover:bg-foreground-0/10", !isActive);
        button.classList.toggle("hover:text-foreground-0", !isActive);
      });
    }

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const filterId = button.getAttribute("data-tool-filter") ?? "all";
        applyFilter(filterId);
      });
    });

    applyFilter("all");
  </script>
</BaseLayout>
