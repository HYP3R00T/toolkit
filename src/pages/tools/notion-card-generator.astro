---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NotionCardGeneratorComponent from "@/components/tools/NotionCardGenerator.tsx";
---

<BaseLayout
  title="Notion Card Generator"
  description="Generate 16:9 Notion gallery card previews with a background, icon, and icon color."
>
  <section class="stripe-pattern-dense relative px-4 py-12 md:px-12">
    <div class="mx-auto w-full max-w-7xl space-y-8">
      <div class="space-y-4">
        <span
          class="border border-accent bg-accent text-background-0 inline-flex w-fit px-3 py-1 text-xs font-medium tracking-wide uppercase"
        >
          Tool
        </span>
        <h1 class="text-section-heading">
          <div>Notion</div>
          <div>Card Generator</div>
        </h1>
        <p
          class="text-foreground-1 max-w-3xl text-base leading-relaxed md:text-lg"
        >
          Build a 16:9 preview image for Notion gallery cards. Choose a
          background, icon, and icon color, then download a PNG that you can
          upload to a Files & Media property.
        </p>
      </div>

      <NotionCardGeneratorComponent client:load />
    </div>
  </section>
</BaseLayout>
